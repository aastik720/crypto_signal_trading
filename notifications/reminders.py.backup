# ============================================
# CRYPTO SIGNAL BOT - REMINDER SYSTEM
# ============================================
# Manages subscription expiry notifications.
#
# Reminder schedule:
#   Day 25 (3 days left)  → Friendly warning
#   Day 27 (1 day left)   → Urgent warning
#   Day 28 (expiry day)   → Expired notice
#   Day 29 (1 day after)  → Soft comeback #1
#   Day 30 (2 days after) → Soft comeback #2
#   Day 31 (3 days after) → Final comeback
#   Day 32+               → STOP (no more reminders)
#
# Anti-spam rules:
#   - Each reminder type sent ONCE per user
#   - Minimum 12 hours between any reminders
#   - Blocked users skipped automatically
#   - Errors per-user don't stop batch processing
#
# Scheduled via:
#   process_all_reminders() — called every 6 hours
#
# Usage:
#   from notifications.reminders import reminder_manager
#   await reminder_manager.process_all_reminders()
# ============================================

import logging
from datetime import datetime, timedelta, date

from config.settings import Config

# ============================================
# OPTIONAL IMPORTS (graceful fallback)
# ============================================

try:
    from database.db_manager import db as db_manager
    DB_AVAILABLE = True
except ImportError:
    db_manager = None
    DB_AVAILABLE = False
    print("[REMINDER] ⚠️ Database not available — "
          "using in-memory tracking")

try:
    from telegram import InlineKeyboardButton, InlineKeyboardMarkup
    from telegram.constants import ParseMode
    TG_AVAILABLE = True
except ImportError:
    TG_AVAILABLE = False
    ParseMode = None
    print("[REMINDER] ⚠️ Telegram library not available")

# ============================================
# LOGGING
# ============================================

logger = logging.getLogger("reminders")

# ============================================
# CONSTANTS
# ============================================

REMINDER_TYPES = {
    "3_DAY_WARNING": "3_day",
    "1_DAY_WARNING": "1_day",
    "EXPIRED": "expired",
    "POST_EXPIRY_1": "post_1",
    "POST_EXPIRY_2": "post_2",
    "POST_EXPIRY_3": "post_3",
}

# Minimum hours between any two reminders to same user
MIN_REMINDER_GAP_HOURS = 12

# Stop post-expiry reminders after this many days
MAX_POST_EXPIRY_DAYS = 3

DATE_FORMAT = "%Y-%m-%d %H:%M:%S"


class ReminderManager:
    """
    Subscription expiry reminder system.

    Tracks which reminders have been sent to each user
    to prevent duplicate notifications. Processes all
    users in a single batch with per-user error isolation.

    Reminder logic:
    - Calculates days_remaining for each subscriber
    - Maps days_remaining to the appropriate reminder
    - Checks if that reminder was already sent
    - Sends if not yet sent, records if sent
    - For expired users, tracks days_since_expiry
    - Stops post-expiry reminders after 3 days

    Attributes:
        bot:                      Telegram bot instance
        _reminder_log (dict):     {chat_id: {type: timestamp}}
        _reminder_counts (dict):  {chat_id: int}
        _signal_counts (dict):    {chat_id: int} (for stats)
        _blocked_users (set):     Users who blocked the bot
        _stats (dict):            Processing statistics
    """

    # ============================================
    # FUNCTION 1: __init__
    # ============================================

    def __init__(self, bot_instance=None):
        """
        Initialize the Reminder Manager.

        Args:
            bot_instance: CryptoSignalBot instance.
                         Can be set later via set_bot().
                         Required for sending messages.
        """
        self.bot = bot_instance

        # ------ Reminder tracking ------
        # {chat_id: {"3_day": "2024-01-25 10:00:00", ...}}
        self._reminder_log = {}

        # {chat_id: total_reminders_sent}
        self._reminder_counts = {}

        # {chat_id: signals_received_count}
        self._signal_counts = {}

        # ------ Blocked users ------
        self._blocked_users = set()

        # ------ Processing stats ------
        self._stats = {
            "total_processed": 0,
            "total_sent": 0,
            "total_skipped": 0,
            "total_failed": 0,
            "total_blocked": 0,
            "last_run": None,
            "last_run_details": {},
        }

        # ------ Config ------
        try:
            self._sub_price = Config.SUBSCRIPTION_PRICE
        except AttributeError:
            self._sub_price = 999

        try:
            self._sub_days = Config.SUBSCRIPTION_DAYS
        except AttributeError:
            self._sub_days = 28

        print("[REMINDER] ✅ Reminder Manager initialized")
        print("[REMINDER]    Min gap: {} hours".format(
            MIN_REMINDER_GAP_HOURS
        ))
        print("[REMINDER]    Post-expiry limit: {} days".format(
            MAX_POST_EXPIRY_DAYS
        ))

    # ============================================
    # FUNCTION 2: SET BOT
    # ============================================

    def set_bot(self, bot_instance):
        """
        Set or update the bot instance.

        Args:
            bot_instance: CryptoSignalBot with application
        """
        self.bot = bot_instance
        print("[REMINDER] ✅ Bot instance linked")

    # ============================================
    # FUNCTION 3: KEYBOARD BUILDERS
    # ============================================

    def _get_renew_keyboard(self):
        """
        Build 'Renew Now' inline keyboard.

        Returns:
            InlineKeyboardMarkup or None
        """
        try:
            if not TG_AVAILABLE:
                return None

            keyboard = [
                [InlineKeyboardButton(
                    "🔄 Renew Now",
                    callback_data="get_premium"
                )],
            ]
            return InlineKeyboardMarkup(keyboard)

        except Exception:
            return None

    def _get_renew_stats_keyboard(self):
        """
        Build 'Renew + Stats' inline keyboard.

        Returns:
            InlineKeyboardMarkup or None
        """
        try:
            if not TG_AVAILABLE:
                return None

            keyboard = [
                [
                    InlineKeyboardButton(
                        "🔄 Renew Now",
                        callback_data="get_premium"
                    ),
                    InlineKeyboardButton(
                        "📊 My Stats",
                        callback_data="my_status"
                    ),
                ],
            ]
            return InlineKeyboardMarkup(keyboard)

        except Exception:
            return None

    def _get_comeback_keyboard(self):
        """
        Build 'Come Back' inline keyboard with
        renew and help buttons.

        Returns:
            InlineKeyboardMarkup or None
        """
        try:
            if not TG_AVAILABLE:
                return None

            keyboard = [
                [InlineKeyboardButton(
                    "🔄 Renew Now — ₹{}".format(self._sub_price),
                    callback_data="get_premium"
                )],
                [InlineKeyboardButton(
                    "ℹ️ What did I miss?",
                    callback_data="help"
                )],
            ]
            return InlineKeyboardMarkup(keyboard)

        except Exception:
            return None

    # ============================================
    # FUNCTION 4: SEND MESSAGE HELPER
    # ============================================

    async def _send_message(self, chat_id, text, keyboard=None):
        """
        Send a message to a user via the bot.

        Handles all Telegram API errors:
        - 403 Forbidden → user blocked bot
        - 400 Bad Request → invalid chat / deleted
        - Other errors → logged, not fatal

        Args:
            chat_id (int):              Target chat ID
            text (str):                 HTML message
            keyboard (InlineKeyboard):  Optional buttons

        Returns:
            str: "sent", "blocked", or "failed"
        """
        try:
            if not self.bot:
                print("[REMINDER] ⚠️ No bot instance")
                return "failed"

            if (not self.bot.application or
                    not self.bot.application.bot):
                print("[REMINDER] ⚠️ Bot application not ready")
                return "failed"

            if chat_id in self._blocked_users:
                return "blocked"

            kwargs = {
                "chat_id": chat_id,
                "text": text,
            }

            if TG_AVAILABLE and ParseMode:
                kwargs["parse_mode"] = ParseMode.HTML

            if keyboard:
                kwargs["reply_markup"] = keyboard

            await self.bot.application.bot.send_message(**kwargs)

            return "sent"

        except Exception as e:
            error_str = str(e).lower()

            if ("forbidden" in error_str or
                    "blocked" in error_str or
                    "deactivated" in error_str or
                    "kicked" in error_str):
                self._blocked_users.add(chat_id)
                print("[REMINDER] 🚫 User {} blocked bot".format(
                    chat_id
                ))
                return "blocked"

            elif ("bad request" in error_str or
                  "chat not found" in error_str):
                self._blocked_users.add(chat_id)
                return "blocked"

            else:
                print("[REMINDER] ❌ Send to {} failed: "
                      "{}".format(chat_id, e))
                return "failed"

    # ============================================
    # FUNCTION 5: REMINDER TRACKING
    # ============================================

    def _was_reminder_sent(self, chat_id, reminder_type):
        """
        Check if a specific reminder was already sent
        to this user.

        Args:
            chat_id (int):         User's chat ID
            reminder_type (str):   Reminder category

        Returns:
            bool: True if already sent
        """
        try:
            user_log = self._reminder_log.get(chat_id, {})
            return reminder_type in user_log

        except Exception:
            return False

    def _can_send_reminder(self, chat_id):
        """
        Check if enough time has passed since the
        last reminder to this user.

        Enforces MIN_REMINDER_GAP_HOURS between
        any two reminders.

        Args:
            chat_id (int): User's chat ID

        Returns:
            bool: True if gap is sufficient
        """
        try:
            user_log = self._reminder_log.get(chat_id, {})

            if not user_log:
                return True

            # Find the most recent reminder timestamp
            latest = None
            for rtype, timestamp_str in user_log.items():
                try:
                    ts = datetime.strptime(
                        timestamp_str, DATE_FORMAT
                    )
                    if latest is None or ts > latest:
                        latest = ts
                except (ValueError, TypeError):
                    continue

            if latest is None:
                return True

            hours_since = (
                datetime.now() - latest
            ).total_seconds() / 3600.0

            return hours_since >= MIN_REMINDER_GAP_HOURS

        except Exception:
            return True

    def _record_reminder(self, chat_id, reminder_type):
        """
        Record that a reminder was sent to a user.

        Args:
            chat_id (int):         User's chat ID
            reminder_type (str):   Reminder category
        """
        try:
            if chat_id not in self._reminder_log:
                self._reminder_log[chat_id] = {}

            self._reminder_log[chat_id][reminder_type] = \
                datetime.now().strftime(DATE_FORMAT)

            # Increment count
            current = self._reminder_counts.get(chat_id, 0)
            self._reminder_counts[chat_id] = current + 1

        except Exception as e:
            print("[REMINDER] ❌ Record error: {}".format(e))

    def _get_signal_count(self, chat_id):
        """
        Get total signals received by a user.

        Checks multiple sources:
        1. Internal counter
        2. Bot's signal counter
        3. Database

        Args:
            chat_id (int): User's chat ID

        Returns:
            int: Signal count
        """
        try:
            # Internal
            count = self._signal_counts.get(chat_id, 0)
            if count > 0:
                return count

            # Bot memory
            if self.bot:
                try:
                    count = self.bot._db_get_signal_count(chat_id)
                    if count and count > 0:
                        return int(count)
                except Exception:
                    pass

            # Database
            if DB_AVAILABLE and db_manager:
                try:
                    count = db_manager.get_signal_count(chat_id)
                    if count and count > 0:
                        return int(count)
                except Exception:
                    pass

            return 0

        except Exception:
            return 0

    # ============================================
    # FUNCTION 6: 3-DAY WARNING
    # ============================================

    async def send_3_day_warning(self, chat_id, expiry_date):
        """
        Send friendly 3-day expiry warning.

        Tone: Informative, gentle nudge
        Sent: When 3 days remain (Day 25 of 28)

        Args:
            chat_id (int):        User's chat ID
            expiry_date (str):    Expiry date string

        Returns:
            bool: True if sent successfully
        """
        reminder_type = REMINDER_TYPES["3_DAY_WARNING"]

        try:
            # Check if already sent
            if self._was_reminder_sent(chat_id, reminder_type):
                return False

            # Check gap
            if not self._can_send_reminder(chat_id):
                return False

            # Format expiry date for display
            expiry_display = self._format_date(expiry_date)

            message = (
                "⚠️ <b>Subscription Expiring Soon!</b>\n"
                "\n"
                "⏳ Your premium access expires in "
                "<b>3 days</b>\n"
                "📅 Expiry date: <b>{expiry}</b>\n"
                "\n"
                "You've been receiving great trading "
                "signals! Don't let them stop.\n"
                "\n"
                "Renew now to keep the signals flowing:\n"
                "💰 <b>₹{price} for {days} more days</b>\n"
                "\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━"
            ).format(
                expiry=expiry_display,
                price=self._sub_price,
                days=self._sub_days,
            )

            result = await self._send_message(
                chat_id, message, self._get_renew_keyboard()
            )

            if result == "sent":
                self._record_reminder(chat_id, reminder_type)
                print("[REMINDER] 📧 3-day warning sent "
                      "to {}".format(chat_id))
                return True
            elif result == "blocked":
                self._stats["total_blocked"] += 1
                return False
            else:
                self._stats["total_failed"] += 1
                return False

        except Exception as e:
            print("[REMINDER] ❌ 3-day warning error for "
                  "{}: {}".format(chat_id, e))
            return False

    # ============================================
    # FUNCTION 7: 1-DAY WARNING
    # ============================================

    async def send_1_day_warning(self, chat_id, expiry_date):
        """
        Send urgent 1-day expiry warning.

        Tone: Urgent, emphasize what they'll lose
        Sent: When 1 day remains (Day 27 of 28)

        Args:
            chat_id (int):        User's chat ID
            expiry_date (str):    Expiry date string

        Returns:
            bool: True if sent successfully
        """
        reminder_type = REMINDER_TYPES["1_DAY_WARNING"]

        try:
            if self._was_reminder_sent(chat_id, reminder_type):
                return False

            if not self._can_send_reminder(chat_id):
                return False

            expiry_display = self._format_date(expiry_date)
            signal_count = self._get_signal_count(chat_id)

            message = (
                "🚨 <b>URGENT: Subscription Expires "
                "Tomorrow!</b>\n"
                "\n"
                "⏳ Less than <b>24 hours</b> remaining!\n"
                "📅 Expiry: <b>{expiry}</b>\n"
                "\n"
                "📊 <b>Your journey so far:</b>\n"
                "• Signals received: <b>{signals}</b>\n"
                "• Days active: <b>{days}</b>\n"
                "\n"
                "Don't miss out on profitable signals!\n"
                "\n"
                "💰 Renew for just <b>₹{price}</b> — "
                "that's less than ₹{per_day}/day\n"
                "\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━"
            ).format(
                expiry=expiry_display,
                signals=signal_count,
                days=self._sub_days,
                price=self._sub_price,
                per_day=round(self._sub_price / self._sub_days),
            )

            result = await self._send_message(
                chat_id, message, self._get_renew_stats_keyboard()
            )

            if result == "sent":
                self._record_reminder(chat_id, reminder_type)
                print("[REMINDER] 🚨 1-day warning sent "
                      "to {}".format(chat_id))
                return True
            elif result == "blocked":
                self._stats["total_blocked"] += 1
                return False
            else:
                self._stats["total_failed"] += 1
                return False

        except Exception as e:
            print("[REMINDER] ❌ 1-day warning error for "
                  "{}: {}".format(chat_id, e))
            return False

    # ============================================
    # FUNCTION 8: EXPIRED MESSAGE
    # ============================================

    async def send_expired_message(self, chat_id):
        """
        Send subscription expired notification.

        Tone: Clear and factual, show what they had
        Sent: On expiry day (Day 28 of 28)

        Args:
            chat_id (int): User's chat ID

        Returns:
            bool: True if sent successfully
        """
        reminder_type = REMINDER_TYPES["EXPIRED"]

        try:
            if self._was_reminder_sent(chat_id, reminder_type):
                return False

            if not self._can_send_reminder(chat_id):
                return False

            signal_count = self._get_signal_count(chat_id)

            message = (
                "❌ <b>Subscription Expired</b>\n"
                "\n"
                "Your premium access has ended.\n"
                "You will no longer receive trading "
                "signals.\n"
                "\n"
                "📊 <b>Your stats:</b>\n"
                "• Signals received: <b>{signals}</b>\n"
                "• Days active: <b>{days}</b>\n"
                "• Avg signals/day: <b>{avg:.1f}</b>\n"
                "\n"
                "Renew anytime to resume:\n"
                "💰 <b>₹{price} for {days} days</b>\n"
                "\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━"
            ).format(
                signals=signal_count,
                days=self._sub_days,
                avg=signal_count / max(1, self._sub_days),
                price=self._sub_price,
            )

            result = await self._send_message(
                chat_id, message, self._get_renew_keyboard()
            )

            if result == "sent":
                self._record_reminder(chat_id, reminder_type)
                print("[REMINDER] ❌ Expired notice sent "
                      "to {}".format(chat_id))
                return True
            elif result == "blocked":
                self._stats["total_blocked"] += 1
                return False
            else:
                self._stats["total_failed"] += 1
                return False

        except Exception as e:
            print("[REMINDER] ❌ Expired msg error for "
                  "{}: {}".format(chat_id, e))
            return False

    # ============================================
    # FUNCTION 9: POST-EXPIRY REMINDERS
    # ============================================

    async def send_post_expiry_reminder(self, chat_id,
                                         days_since):
        """
        Send soft comeback reminder after expiry.

        Tone: Friendly, non-pushy, value-focused
        Sent: Days 1, 2, 3 after expiry then STOPS

        Different message each day:
        - Day 1: "We miss you" + recent market highlight
        - Day 2: "Signals you missed" + renewal deal
        - Day 3: "Final reminder" + last chance tone

        Args:
            chat_id (int):       User's chat ID
            days_since (int):    Days since expiry (1-3)

        Returns:
            bool: True if sent successfully
        """
        try:
            # Don't send after day 3
            if days_since > MAX_POST_EXPIRY_DAYS:
                return False

            if days_since < 1:
                return False

            reminder_type = REMINDER_TYPES.get(
                "POST_EXPIRY_{}".format(days_since)
            )
            if not reminder_type:
                return False

            if self._was_reminder_sent(chat_id, reminder_type):
                return False

            if not self._can_send_reminder(chat_id):
                return False

            # Select message based on days_since
            if days_since == 1:
                message = self._post_expiry_day1()
            elif days_since == 2:
                message = self._post_expiry_day2()
            else:
                message = self._post_expiry_day3()

            result = await self._send_message(
                chat_id, message, self._get_comeback_keyboard()
            )

            if result == "sent":
                self._record_reminder(chat_id, reminder_type)
                print("[REMINDER] 💌 Post-expiry day {} "
                      "sent to {}".format(days_since, chat_id))
                return True
            elif result == "blocked":
                self._stats["total_blocked"] += 1
                return False
            else:
                self._stats["total_failed"] += 1
                return False

        except Exception as e:
            print("[REMINDER] ❌ Post-expiry error for "
                  "{}: {}".format(chat_id, e))
            return False

