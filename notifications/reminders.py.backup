        ).format(
            price=self._sub_price,
            days=self._sub_days,
        )

    # ============================================
    # FUNCTION 10: CHECK EXPIRING SUBSCRIPTIONS
    # ============================================

    async def check_expiring_subscriptions(self):
        """
        Find users with expiring/expired subscriptions
        and send appropriate reminders.

        Called every 6 hours by the scheduler.

        Pipeline:
        1. Get all subscriptions (active + recently expired)
        2. Calculate days_remaining for each
        3. Route to correct reminder function
        4. Track results

        Days remaining mapping:
          3 days left  → send_3_day_warning()
          1 day left   → send_1_day_warning()
          0 (today)    → send_expired_message()
          -1 to -3     → send_post_expiry_reminder()
          < -3         → skip (stop reminding)

        Returns:
            dict: {
                "checked": int,
                "warnings_3day": int,
                "warnings_1day": int,
                "expired": int,
                "post_expiry": int,
                "skipped": int,
                "blocked": int,
                "failed": int,
            }
        """
        results = {
            "checked": 0,
            "warnings_3day": 0,
            "warnings_1day": 0,
            "expired": 0,
            "post_expiry": 0,
            "skipped": 0,
            "blocked": 0,
            "failed": 0,
        }

        try:
            # Get all subscriptions
            all_subs = self._get_all_subscriptions()

            if not all_subs:
                print("[REMINDER] ℹ️ No subscriptions to check")
                return results

            now = datetime.now()

            print("[REMINDER] 🔍 Checking {} "
                  "subscription(s)...".format(len(all_subs)))

            for chat_id, sub_data in all_subs.items():
                results["checked"] += 1

                try:
                    # Skip blocked users
                    if chat_id in self._blocked_users:
                        results["blocked"] += 1
                        continue

                    # Parse expiry date
                    end_str = sub_data.get(
                        "end_date",
                        sub_data.get("expires_at", "")
                    )

                    if not end_str:
                        results["skipped"] += 1
                        continue

                    end_dt = self._parse_date(end_str)
                    if not end_dt:
                        results["skipped"] += 1
                        continue

                    # Calculate days remaining
                    delta = end_dt - now
                    days_remaining = delta.days

                    # Route to correct reminder
                    sent = False

                    if days_remaining == 3:
                        sent = await self.send_3_day_warning(
                            chat_id, end_str
                        )
                        if sent:
                            results["warnings_3day"] += 1

                    elif days_remaining == 1:
                        sent = await self.send_1_day_warning(
                            chat_id, end_str
                        )
                        if sent:
                            results["warnings_1day"] += 1

                    elif days_remaining == 0:
                        sent = await self.send_expired_message(
                            chat_id
                        )
                        if sent:
                            results["expired"] += 1

                    elif -MAX_POST_EXPIRY_DAYS <= days_remaining < 0:
                        days_since = abs(days_remaining)
                        sent = await self.send_post_expiry_reminder(
                            chat_id, days_since
                        )
                        if sent:
                            results["post_expiry"] += 1

                    else:
                        results["skipped"] += 1

                except Exception as e:
                    print("[REMINDER] ❌ Error processing "
                          "chat:{} — {}".format(chat_id, e))
                    results["failed"] += 1
                    continue

            return results

        except Exception as e:
            print("[REMINDER] ❌ Check expiring error: "
                  "{}".format(e))
            return results

    # ============================================
    # FUNCTION 11: PROCESS ALL REMINDERS (MAIN)
    # ============================================

    async def process_all_reminders(self):
        """
        Main entry point — process all reminder types.

        Called by the scheduler every 6 hours.

        Pipeline:
        1. Log start time
        2. Run check_expiring_subscriptions()
        3. Update processing stats
        4. Log summary

        Error handling:
        - Per-user errors don't stop batch
        - Global errors caught and logged
        - Always returns a result dict

        Returns:
            dict: Processing results summary
        """
        try:
            start_time = datetime.now()

            print("\n[REMINDER] ══════════════════════════════")
            print("[REMINDER]  📧 Processing Reminders")
            print("[REMINDER]  Started: {}".format(
                start_time.strftime("%H:%M:%S")
            ))
            print("[REMINDER] ══════════════════════════════")

            # Run all checks
            results = await self.check_expiring_subscriptions()

            # Calculate duration
            duration = (
                datetime.now() - start_time
            ).total_seconds()

            # Update global stats
            self._stats["total_processed"] += results["checked"]
            self._stats["total_sent"] += (
                results["warnings_3day"] +
                results["warnings_1day"] +
                results["expired"] +
                results["post_expiry"]
            )
            self._stats["total_skipped"] += results["skipped"]
            self._stats["total_failed"] += results["failed"]
            self._stats["total_blocked"] += results["blocked"]
            self._stats["last_run"] = start_time.strftime(
                DATE_FORMAT
            )
            self._stats["last_run_details"] = results

            # Log summary
            total_sent = (
                results["warnings_3day"] +
                results["warnings_1day"] +
                results["expired"] +
                results["post_expiry"]
            )

            print("\n[REMINDER] ══════════════════════════════")
            print("[REMINDER]  📧 Reminder Processing Complete")
            print("[REMINDER]  Checked    : {}".format(
                results["checked"]
            ))
            print("[REMINDER]  3-day warn : {}".format(
                results["warnings_3day"]
            ))
            print("[REMINDER]  1-day warn : {}".format(
                results["warnings_1day"]
            ))
            print("[REMINDER]  Expired    : {}".format(
                results["expired"]
            ))
            print("[REMINDER]  Post-expiry: {}".format(
                results["post_expiry"]
            ))
            print("[REMINDER]  Skipped    : {}".format(
                results["skipped"]
            ))
            print("[REMINDER]  Blocked    : {}".format(
                results["blocked"]
            ))
            print("[REMINDER]  Failed     : {}".format(
                results["failed"]
            ))
            print("[REMINDER]  Total sent : {}".format(total_sent))
            print("[REMINDER]  Duration   : {:.2f}s".format(
                duration
            ))
            print("[REMINDER] ══════════════════════════════\n")

            logger.info(
                "Reminders processed: {} checked, {} sent, "
                "{} failed in {:.2f}s".format(
                    results["checked"], total_sent,
                    results["failed"], duration,
                )
            )

            return results

        except Exception as e:
            print("[REMINDER] ❌ Process all error: {}".format(e))
            logger.error("Reminder processing failed: {}".format(e))
            return {
                "checked": 0,
                "warnings_3day": 0,
                "warnings_1day": 0,
                "expired": 0,
                "post_expiry": 0,
                "skipped": 0,
                "blocked": 0,
                "failed": 1,
                "error": str(e),
            }

    # ============================================
    # FUNCTION 12: SEND CUSTOM REMINDER
    # ============================================

    async def send_custom_reminder(self, chat_id, message,
                                    keyboard=None):
        """
        Send a custom reminder to a specific user.

        Used for one-off notifications like:
        - Special promotions
        - System announcements
        - Manual admin messages

        Respects gap rules and blocked user list.

        Args:
            chat_id (int):     Target user
            message (str):     HTML message
            keyboard:          Optional inline keyboard

        Returns:
            bool: True if sent
        """
        try:
            if chat_id in self._blocked_users:
                return False

            if not self._can_send_reminder(chat_id):
                print("[REMINDER] ⏳ Gap not met for "
                      "{}".format(chat_id))
                return False

            result = await self._send_message(
                chat_id, message, keyboard
            )

            if result == "sent":
                self._record_reminder(chat_id, "custom")
                return True
            return False

        except Exception as e:
            print("[REMINDER] ❌ Custom reminder error: "
                  "{}".format(e))
            return False

    # ============================================
    # DATA ACCESS HELPERS
    # ============================================

    def _get_all_subscriptions(self):
        """
        Get all subscriptions (active + recently expired).

        Merges data from database and bot's memory.

        Returns:
            dict: {chat_id: sub_data, ...}
        """
        subs = {}

        try:
            # From bot memory
            if self.bot:
                try:
                    for cid, data in self.bot._mem_subs.items():
                        subs[cid] = data
                except Exception:
                    pass

            # From database
            if DB_AVAILABLE and db_manager:
                try:
                    db_subs = db_manager.get_all_subscriptions()
                    if db_subs:
                        if isinstance(db_subs, dict):
                            subs.update(db_subs)
                        elif isinstance(db_subs, list):
                            for s in db_subs:
                                cid = s.get("chat_id")
                                if cid:
                                    subs[cid] = s
                except Exception:
                    pass

            # From auth module
            try:
                from security.auth import auth_manager
                for cid, data in auth_manager._subscriptions.items():
                    if cid not in subs:
                        subs[cid] = data
            except Exception:
                pass

            return subs

        except Exception as e:
            print("[REMINDER] ❌ Get subs error: {}".format(e))
            return subs

    def _parse_date(self, date_str):
        """
        Parse a date string into datetime object.

        Tries multiple formats for compatibility.

        Args:
            date_str: Date string or datetime object

        Returns:
            datetime or None
        """
        try:
            if isinstance(date_str, datetime):
                return date_str

            if not isinstance(date_str, str):
                return None

            # Try standard format
            formats = [
                "%Y-%m-%d %H:%M:%S",
                "%Y-%m-%d %H:%M",
                "%Y-%m-%d",
                "%d/%m/%Y %H:%M:%S",
                "%d/%m/%Y",
            ]

            for fmt in formats:
                try:
                    return datetime.strptime(date_str, fmt)
                except ValueError:
                    continue

            return None

        except Exception:
            return None

    def _format_date(self, date_str):
        """
        Format a date string for user display.

        Converts to "DD Mon YYYY" format.

        Args:
            date_str: Date string or datetime

        Returns:
            str: Formatted date string
        """
        try:
            dt = self._parse_date(date_str)
            if dt:
                return dt.strftime("%d %b %Y")

            if isinstance(date_str, str) and len(date_str) >= 10:
                return date_str[:10]

            return str(date_str)

        except Exception:
            return str(date_str)

    # ============================================
    # FUNCTION 13: STATISTICS
    # ============================================

    def get_stats(self):
        """
        Get reminder system statistics.

        Returns:
            dict: Processing stats and user metrics
        """
        try:
            return {
                "total_processed": self._stats["total_processed"],
                "total_sent": self._stats["total_sent"],
                "total_skipped": self._stats["total_skipped"],
                "total_failed": self._stats["total_failed"],
                "total_blocked": self._stats["total_blocked"],
                "blocked_users": len(self._blocked_users),
                "tracked_users": len(self._reminder_log),
                "last_run": self._stats["last_run"],
                "last_run_details": self._stats[
                    "last_run_details"
                ],
            }

        except Exception:
            return {}

    def get_user_reminder_history(self, chat_id):
        """
        Get reminder history for a specific user.

        Args:
            chat_id (int): User's chat ID

        Returns:
            dict: {reminder_type: timestamp, ...}
        """
        return self._reminder_log.get(chat_id, {})

    def reset_user_reminders(self, chat_id):
        """
        Reset reminder tracking for a user.

        Called when a user renews their subscription
        so they can receive reminders again for their
        new subscription period.

        Args:
            chat_id (int): User's chat ID
        """
        try:
            if chat_id in self._reminder_log:
                del self._reminder_log[chat_id]

            if chat_id in self._reminder_counts:
                del self._reminder_counts[chat_id]

            print("[REMINDER] 🔄 Reminders reset for "
                  "chat:{}".format(chat_id))

        except Exception as e:
            print("[REMINDER] ❌ Reset error: {}".format(e))

    def add_signal_count(self, chat_id, count=1):
        """
        Update signal count for stats display.

        Args:
            chat_id (int): User's chat ID
            count (int):   Signals to add
        """
        try:
            current = self._signal_counts.get(chat_id, 0)
            self._signal_counts[chat_id] = current + count
        except Exception:
            pass


# ==================================================
# MODULE-LEVEL SINGLETON
# ==================================================

reminder_manager = ReminderManager()

print("[REMINDER] ✅ Reminder system loaded and ready")