# ============================================
# CRYPTO SIGNAL BOT - ENVIRONMENT VARIABLES
# ============================================

# --- Telegram Configuration ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLIC_CHANNEL_ID=

# --- Admin (comma separated chat IDs) ---
ADMIN_CHAT_IDS=

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Payment Mode Toggle ---
# "fake" = generates tokens manually for testing (no real money)
# "real" = connects to Razorpay for actual payment processing
PAYMENT_MODE=fake

# --- Subscription Settings ---
SUBSCRIPTION_PRICE=999
SUBSCRIPTION_DAYS=28

# --- Signal Settings ---
PUBLIC_CHANNEL_DAILY_LIMIT=2
SIGNAL_INTERVAL_MINUTES=25
MIN_CONFIDENCE_SCORE=65
TIMEFRAME=5m


# --- RSI Brain ---
RSI_PERIOD=14

# --- MACD Brain ---
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# --- Bollinger Brain ---
BOLLINGER_PERIOD=20
BOLLINGER_STD=2.0

# --- Volume Brain ---
VOLUME_MA_PERIOD=20


# --- Database ---
DATABASE_PATH=database/crypto_bot.db

# --- Logging ---
LOG_FILE_PATH=utils/bot_logs.log